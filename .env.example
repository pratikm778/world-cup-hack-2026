# GMI Cloud API - smoke target: google/gemini-3.5-flash at https://api.gmi-serving.com/v1
# Used by direct curl / app-side calls.
GMI_API_KEY=

# Default LLM on GMI Cloud (oracle_app, Signal Desk ranking, etc.)
GMI_MODEL=google/gemini-3.5-flash

# Same key, ROCKETRIDE_-prefixed so it interpolates into .pipe files.
# (Per docs: only ROCKETRIDE_-prefixed vars are substituted in .pipe configs.)
ROCKETRIDE_GMI_API_KEY=

# EdgeCast agent IO server (scripts/agent_io_server.py)
EDGECAST_MATCH_ID=ars-man-2026-04-19
EDGECAST_SESSION_ID=edgecast-ars-man-2026-04-19
EDGECAST_TICK_GAME_MINUTES=5
EDGECAST_TICK_POLL_SECONDS=1
EDGECAST_CONTEXT_RECENT_MIN=15
EDGECAST_BROADCAST_HISTORY=10
EDGECAST_CHAT_HISTORY=20
EDGECAST_CHAT_IN_TICK=6
EDGECAST_LOOKBACK_MIN=5
EDGECAST_TOP_MOVERS=5
EDGECAST_TICK_ENABLED=1
EDGECAST_WEBHOOK_URL=http://localhost:8080/api/pipelines/test.pipe/webhook

# Exa search (direct API + RocketRide pipe interpolation)
EXA_API_KEY=
EXA_BASE_URL=https://api.exa.ai/search
ROCKETRIDE_EXA_KEY=

# RocketRide RAG knowledge base (knowledge_ingest.pipe + test.pipe tool_pipe branch)
# Chroma: docker run -p 8330:8000 chromadb/chroma
ROCKETRIDE_CHROMA_HOST=localhost
ROCKETRIDE_CHROMA_COLLECTION=edgecast-knowledge
